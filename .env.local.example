# ─────────────────────────────────────────────────────────────────────────────
# Copia questo file in .env e modificalo prima di avviare il deploy locale.
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootsecret123
MYSQL_DATABASE=posmanager
MYSQL_USER=posmanager
MYSQL_PASSWORD=posmanager123

DATABASE_URL=mysql+asyncmy://posmanager:posmanager123@mysql:3306/posmanager

# ── Auth ──────────────────────────────────────────────────────────────────────
# Genera una chiave casuale: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SOSTITUISCI_CON_STRINGA_CASUALE_64_CHAR
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── IP del mini PC in LAN (es. 192.168.1.100) ────────────────────────────────
LOCAL_IP=192.168.1.100

# ── Admin iniziale ────────────────────────────────────────────────────────────
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=cambiami123

# ── Inventario CSV/Excel (path Windows con slash forward) ────────────────────
# Lascia vuoto se i file non sono su questo PC
INVENTORY_HOST_PATH=
INVENTORY_CSV_DIR=/inventory
