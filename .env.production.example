# ── .env.production.example ───────────────────────────────────────────────────
# Copia in .env sul server e compila tutti i valori.
#
#   cp .env.production.example .env
#   nano .env
#
# ATTENZIONE: il file .env NON deve mai essere committato su git!
# ──────────────────────────────────────────────────────────────────────────────

# ── Dominio e SSL ─────────────────────────────────────────────────────────────
# Il dominio (senza https://) che punta a questo server
DOMAIN=tuodominio.com

# Email per le notifiche di scadenza certificato Let's Encrypt
CERTBOT_EMAIL=tua@email.com

# Includi www.DOMAIN nel certificato SSL? (true/false)
# Imposta false se non hai un record DNS per www.tuodominio.com
CERTBOT_WWW=true

# ── Database MySQL ────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CAMBIA_QUESTA_PASSWORD_ROOT
MYSQL_DATABASE=posmanager
MYSQL_USER=posmanager
MYSQL_PASSWORD=CAMBIA_QUESTA_PASSWORD_DB

# URL di connessione asyncmy (usato dal backend)
# Non modificare il formato, sostituisci solo le password sopra e
# questa URL punterà automaticamente al container mysql via Docker network.
DATABASE_URL=mysql+asyncmy://posmanager:CAMBIA_QUESTA_PASSWORD_DB@mysql:3306/posmanager

# ── Sicurezza JWT ─────────────────────────────────────────────────────────────
# Genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERA_UNA_CHIAVE_CASUALE_DI_64_CARATTERI_HEX

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Admin iniziale ────────────────────────────────────────────────────────────
# Creato automaticamente al primo avvio se il DB è vuoto
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=CAMBIA_QUESTA_PASSWORD_ADMIN

# ── CORS ─────────────────────────────────────────────────────────────────────
# In produzione nginx proxia tutto → CORS non è necessario per il browser,
# ma il backend lo usa per le chiamate cross-origin dirette (es. test locali).
CORS_ORIGINS=https://tuodominio.com,https://www.tuodominio.com

# ── Discogs ───────────────────────────────────────────────────────────────────
# Token API Discogs (Settings → Developers → Generate Token)
DISCOGS_TOKEN=il_tuo_token_discogs

# Directory interna al container dove vengono salvati i CSV scaricati
# (non cambiare se usi docker-compose.prod.yml standard)
INVENTORY_CSV_DIR=/inventory
